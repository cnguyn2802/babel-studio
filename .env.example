# Optional environment variables — the editor works without any of these

# Google Maps API key (enables address search)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# AI scene agent (enables /api/ai/scene-agent)
# AI_PROVIDER=auto # auto | ollama | qwen | openai | abacus

# Ollama (local LLM)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Qwen / Alibaba Model Studio (OpenAI-compatible)
# QWEN_API_KEY=your_qwen_or_dashscope_api_key
# QWEN_MODEL=qwen3.7-max
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# OpenAI
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-5.5
# OPENAI_REASONING_EFFORT=medium # low | medium | high

# Abacus AI
# ABACUS_AI_DEPLOYMENT_ID=your_abacus_deployment_id
# ABACUS_AI_DEPLOYMENT_TOKEN=your_abacus_deployment_token

# Dev server port (default: 3000)
# PORT=3000
